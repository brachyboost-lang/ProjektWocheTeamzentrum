<UserControl x:Class="ProjektWocheTeamzentrum.Views.MembermanagmentUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProjektWocheTeamzentrum.Views"
             xmlns:vm="clr-namespace:ProjektWocheTeamzentrum.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:MembermanagmentVM/>
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="500*"/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnViewMembers" Content="Show Members" Click="ViewMembers_Click" Grid.Column="1" Grid.Row="1"/>
        <Button Content="Add Member" Command="{Binding AddMemberCommand}" Grid.Column="1" Grid.Row="3"/>
        <Button Content="Delete Member" Command="{Binding DeleteMemberCommand}" Grid.Column="1" Grid.Row="5"/>
        <Button Content="Edit Member" Click="EditMember_Click" Grid.Column="1" Grid.Row="7"/>
        <Button Content="Add to Squad" Click="Back_Click" Grid.Column="1" Grid.Row="9"/>
        <ListView x:Name="MembersListBox"  ItemsSource="{Binding Members}" SelectedItem="{Binding SelectedMember, Mode=TwoWay}" Grid.Column="2" Grid.Row="0" Grid.RowSpan="11" Margin="10" Visibility="Collapsed">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel x:Name="StatsPanel" Grid.Column="2" Grid.Row="1" Grid.RowSpan="9" Margin="10" Background="LightGray">

            <StackPanel Orientation="Horizontal">
                <Label Content="Total Members: "/>
                <Label Content="{Binding TotalMembers}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Content="Squads: "/>
                <Label Content="{Binding SquadsCount}"/>
            </StackPanel>

            <ListView x:Name="SquadsListBox" 
              ItemsSource="{Binding Squads}" 
              SelectedItem="{Binding SelectedSquad, Mode=TwoWay}"
              Height="200">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding SquadName}" Margin="5"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </Grid>
</UserControl>
