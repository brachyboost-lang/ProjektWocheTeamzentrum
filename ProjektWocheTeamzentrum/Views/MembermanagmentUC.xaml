<UserControl x:Class="ProjektWocheTeamzentrum.Views.MembermanagmentUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProjektWocheTeamzentrum.Views"
             xmlns:vm="clr-namespace:ProjektWocheTeamzentrum.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:MembermanagmentVM/>
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="500*"/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnViewMembers" Content="Show Members" Click="ViewMembers_Click" Grid.Column="1" Grid.Row="1"/>
        <Button Content="Add Member" Command="{Binding AddMemberCommand}" Grid.Column="1" Grid.Row="3"/>
        <Button Content="Delete Member" Command="{Binding DeleteMemberCommand}" Grid.Column="1" Grid.Row="5"/>
        <Button Content="Edit Member" Click="EditMember_Click" Grid.Column="1" Grid.Row="7"/>
        <Button Content="Add to Squad" Click="Back_Click" Grid.Column="1" Grid.Row="9"/>
        <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="11" Margin="10">

            <ListView x:Name="MembersListBox" 
              ItemsSource="{Binding Members}" 
              SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
              Visibility="Collapsed" Height="600">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Margin="5" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel x:Name="StatsPanel" 
                Background="{StaticResource TeamBlack}"
                Visibility="Visible">
                <Label Content="Total Members: " Foreground="{StaticResource TeamRed}"/>
                <Label Content="{Binding TotalMembers}" Foreground="{StaticResource TeamWhite}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
