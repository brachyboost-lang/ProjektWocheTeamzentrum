<UserControl x:Class="ProjektWocheTeamzentrum.Views.CreateEventUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ProjektWocheTeamzentrum.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <!-- ALL -->
        <DataTemplate x:Key="AllTemplate">
            <StackPanel>
                <ToggleButton Content="German Time Attack Masters" Margin="0,0,0,10"/>
                <ToggleButton Content="Teamtreffen" Margin="0,0,0,10"/>
                <ToggleButton Content="Rennen (Zuschauen)" Margin="0,0,0,10"/>
                <ToggleButton Content="Meeting" Margin="0,0,0,10"/>
            </StackPanel>
        </DataTemplate>

        <!-- LMU -->
        <DataTemplate x:Key="LMUTemplate">
            <StackPanel>
                <ToggleButton Content="LMP1" Margin="0,0,0,10"/>
                <ToggleButton Content="LMP2" Margin="0,0,0,10"/>
                <ToggleButton Content="GTE" Margin="0,0,0,10"/>
            </StackPanel>
        </DataTemplate>

        <!-- ACC -->
        <DataTemplate x:Key="ACCTemplate">
            <StackPanel>
                <ToggleButton Content="GT3" Margin="0,0,0,10"/>
                <ToggleButton Content="GT4" Margin="0,0,0,10"/>
                <ToggleButton Content="M2" Margin="0,0,0,10"/>
            </StackPanel>
        </DataTemplate>

        <!-- IRACING -->
        <DataTemplate x:Key="iRacingTemplate">
            <StackPanel>
                <ToggleButton Content="TCR" Margin="0,0,0,10"/>
                <ToggleButton Content="GT3" Margin="0,0,0,10"/>
                <ToggleButton Content="LMP2" Margin="0,0,0,10"/>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="40*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition Width="80*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Rectangle Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="7" Grid.RowSpan="7" Fill="LightGray" Margin="5,5,5,5"/>
        <Rectangle Grid.Column="7" Grid.Row="0" Grid.ColumnSpan="4" Grid.RowSpan="7" Fill="LightBlue" Margin="5,5,5,5"/>
        <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="7" Grid.RowSpan="7">
            <DockPanel Margin="22" LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Width="420" Margin="0,0,20,0" HorizontalAlignment="Left">
                    <TextBox x:Name="EventNameTextBox" Width="400" Height="24" Text="Event Name" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBox x:Name="EventDescriptionTextBox" Width="400" Height="60" Text="Event Description" Margin="0,0,0,8" TextWrapping="Wrap" AcceptsReturn="True" HorizontalAlignment="Left"/>
                            <TextBox x:Name="EventLocationTextBox" Width="400" Height="24" Text="Event Location" Margin="0,0,0,8" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                            <RadioButton x:Name="SimulationTypeRadioButton" Tag="All" GroupName="SimulationType" Checked="Radio_Checked" Height="20" Content="All" Margin="0,0,0,8"/>
                            <RadioButton x:Name="SimulationTypeRadioButton2" Tag="LMU" GroupName="SimulationType" Checked="Radio_Checked" Height="20" Content="Le Mans Ultimate" Margin="0,0,0,8"/>
                            <RadioButton x:Name="SimulationTypeRadioButton3" Tag="ACC" GroupName="SimulationType" Checked="Radio_Checked" Height="20" Content="Assetto Corsa Competizione" Margin="0,0,0,8"/>
                            <RadioButton x:Name="SimulationTypeRadioButton4" Tag="IR" GroupName="SimulationType" Checked="Radio_Checked" Height="20" Content="iRacing"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" Width="400" HorizontalAlignment="Left">
                        <DatePicker x:Name="EventDatePicker" Width="200"/>
                        <ComboBox x:Name="TimeComboBox" Width="120" Margin="8,0,0,0">
                            <ComboBoxItem Content="00:00"/>
                            <ComboBoxItem Content="01:00"/>
                            <ComboBoxItem Content="02:00"/>
                            <ComboBoxItem Content="03:00"/>
                            <ComboBoxItem Content="04:00"/>
                            <ComboBoxItem Content="05:00"/>
                            <ComboBoxItem Content="06:00"/>
                            <ComboBoxItem Content="07:00"/>
                            <ComboBoxItem Content="08:00"/>
                            <ComboBoxItem Content="09:00"/>
                            <ComboBoxItem Content="10:00"/>
                            <ComboBoxItem Content="11:00"/>
                            <ComboBoxItem Content="12:00"/>
                            <ComboBoxItem Content="13:00"/>
                            <ComboBoxItem Content="14:00"/>
                            <ComboBoxItem Content="15:00"/>
                            <ComboBoxItem Content="16:00"/>
                            <ComboBoxItem Content="17:00"/>
                            <ComboBoxItem Content="18:00"/>
                            <ComboBoxItem Content="19:00"/>
                            <ComboBoxItem Content="20:00"/>
                            <ComboBoxItem Content="21:00"/>
                            <ComboBoxItem Content="22:00"/>
                            <ComboBoxItem Content="23:00"/>
                        </ComboBox>
        <ContentControl x:Name="CarClassContentControl" Grid.Column="7" Grid.Row="0" Grid.ColumnSpan="4" Grid.RowSpan="7" Margin="16"   />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
