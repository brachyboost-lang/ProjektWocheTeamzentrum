<UserControl x:Class="ProjektWocheTeamzentrum.Views.MembersUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProjektWocheTeamzentrum.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="500*"/>
            
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Button Content="Show Members" Click="ViewMembers_Click" Grid.Column="1" Grid.Row="1"/>
        <Button Content="Add Member" Click="AddMember_Click" Grid.Column="1" Grid.Row="3"/>
        <Button Content="Delete Member" Click="DeleteMember_Click" Grid.Column="1" Grid.Row="5"/>
        <Button Content="Edit Member" Click="EditMember_Click" Grid.Column="1" Grid.Row="7"/>
        <Button Content="Back" Click="Back_Click" Grid.Column="1" Grid.Row="9"/>
        <ListBox x:Name="MembersListBox" Grid.Column="2" Grid.Row="0" Grid.RowSpan="11" Margin="10" Visibility="Hidden"/>
    </Grid>
</UserControl>
