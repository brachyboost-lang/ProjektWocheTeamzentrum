<UserControl x:Class="ProjektWocheTeamzentrum.Views.ShowEventsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProjektWocheTeamzentrum.Views"
             xmlns:vm="clr-namespace:ProjektWocheTeamzentrum.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <vm:SimColorConverter x:Key="SimColorConverter"/>
    </UserControl.Resources>
    <Grid x:Name="CalendarGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <ItemsControl Grid.Column="0" ItemsSource="{Binding ElementName=CalendarGrid, Path=DataContext.MonthDays}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7" Rows="6"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="0.5" Background="White">
                        <StackPanel>
                            <TextBlock Text="{Binding Date.Day}" FontWeight="Bold" Margin="2"/>
                            <ItemsControl ItemsSource="{Binding Events}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="1" Background="{Binding SimulationType, Converter={StaticResource SimColorConverter}}" CornerRadius="2">
                                            <TextBlock Text="{Binding Title}" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Margin="10">
        <Button Content="New Event" Click="NewEvent_Click" Margin="10"/>
        <RadioButton Content="All" GroupName="SimulationFilter" Margin="10"/>
        <RadioButton Content="Le Mans Ultimate" GroupName="SimulationFilter" Margin="10"/>
        <RadioButton Content="Assetto Corsa Competizione" GroupName="SimulationFilter" Margin="10"/>
        <RadioButton Content="iRacing" GroupName="SimulationFilter" Margin="10"/>
        <RadioButton Content="Real Life Motorsport" GroupName="SimulationFilter" Margin="10"/>
        <RadioButton Content="Team Events" GroupName="SimulationFilter" Margin="10"/>
        <ListBox x:Name="EventsListBox" Margin="0,0,0,10" ItemsSource="{Binding Events}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"/>
    </StackPanel>
    </Grid>
</UserControl>
